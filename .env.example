# Copy to .env and adjust to your backend.

# The dev server proxies "/api" to this target (no CORS needed in dev).
# Set this to wherever your backend is listening.
VITE_API_PROXY=http://localhost:3000

# Optional: call the API at an absolute URL instead of the proxied "/api".
# Leave unset to use the proxy above.
# VITE_API_URL=http://localhost:3000/api

# NOTE: admin credentials are verified by the backend (POST /api/login) and are
# never embedded in the client bundle. Configure ADMIN_USERNAME / ADMIN_PASSWORD
# in the backend's environment, not here.
